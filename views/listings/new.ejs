<%- layout('/layouts/boilerplate.ejs') %>
<body>
    <br>
    <div class="row">
        <div class="col-8 offset-2">
            <h3>Enter Listing Details :</h3><br>
            <form action="/listings" method="post" novalidate class="needs-validation">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" class="form-control" name="listing[title]" placeholder="Enter title" required>
                    <div class="invalid-feedback">
                        Invalid Title
                    </div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea placeholder="Add description here" class="form-control" name="listing[description]" required></textarea>
                    <div class="invalid-feedback">
                        Invalid Description
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="image">Image</label>
                    <input type="text" name="listing[image]" class="form-control" placeholder="Add img/URL" >
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="place">location</label>
                            <input type="text" name="listing[location]" placeholder="Enter place" class="form-control" required>
                            <div class="invalid-feedback">
                                Invalid Place
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="country">country</label>
                            <input type="text" name="listing[country]" class="form-control" placeholder="Enter place" required>
                            <div class="invalid-feedback">
                                Invalid Country
                            </div>
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="price">Price</label>
                    <input  name="listing[price]" placeholder="Enter price" class="form-control" required>
                    <div class="invalid-feedback">
                        Invalid Price
                    </div>
                </div>
                <div class="text-center">
                    <button class="btn btn-dark mt-3">Add</button><br><br>
                </div>
            </form>
        </div>
    </div>        
</body>


