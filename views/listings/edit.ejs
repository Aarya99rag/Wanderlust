<%- layout('/layouts/boilerplate.ejs') %>
<body>
    <br>
    <div class="row">
        <div class="col-8 offset-2">
            <h3>Edit Listing Details :</h3><br>
            <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation">
                <div class="mb-3">
                    <label for="title" class="form-label">Title:</label>
                    <input value="<%= listing.title %>" type="text" class="form-control" name="listing[title]" required>
                    <div class="invalid-feedback">
                        Invalid Title
                    </div>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description:</label>
                    <textarea value="<%= listing.description %>" class="form-control" name="listing[description]" required><%= listing.description %></textarea>
                    <div class="invalid-feedback">
                        Invalid Description
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="image">Image:</label>
                    <input type="text" name="listing[image]" class="form-control" value="<%= listing.image %>" required>
                    <div class="invalid-feedback">
                        Invalid Image
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="place">location:</label>
                            <input type="text" name="listing[location]" value="<%= listing.location %>" class="form-control" required>
                            <div class="invalid-feedback">
                                Invalid Location
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" for="country">country:</label>
                            <input type="text" name="listing[country]" class="form-control" value="<%= listing.country %>" required>
                            <div class="invalid-feedback">
                                Invalid Country
                            </div>
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="price">Price:</label>
                    <input type="number" name="listing[price]" value="<%= listing.price %>" class="form-control" required>
                    <div class="invalid-feedback">
                        Invalid Price
                    </div>
                </div>
                <div class="text-center">
                    <button class="btn btn-dark mt-3">Edit</button><br><br>
                </div>
            </form>
        </div>
    </div>
</body>



